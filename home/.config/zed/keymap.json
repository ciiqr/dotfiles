[
    {
        "context": "Editor",
        "bindings": {
            "ctrl-shift-tab": "pane::ActivatePreviousItem",
            "ctrl-tab": "pane::ActivateNextItem",
        },
    },
    {
        "context": "os == macos && Editor",
        "bindings": {
            "ctrl-cmd-p": ["projects::OpenRecent", { "create_new_window": false }],
            "cmd-shift-d": "editor::DuplicateLineDown",
            "ctrl-cmd-up": "editor::MoveLineUp",
            "ctrl-cmd-down": "editor::MoveLineDown",
        },
    },
    {
        "context": "os == linux && Editor",
        "bindings": {
            "ctrl-shift-d": "editor::DuplicateLineDown",
            "ctrl-shift-up": "editor::MoveLineUp",
            "ctrl-shift-down": "editor::MoveLineDown",
        },
    },
    {
        "context": "os == macos && Pane",
        "bindings": {
            "cmd-1": ["pane::ActivateItem", 0],
            "cmd-2": ["pane::ActivateItem", 1],
            "cmd-3": ["pane::ActivateItem", 2],
            "cmd-4": ["pane::ActivateItem", 3],
            "cmd-5": ["pane::ActivateItem", 4],
            "cmd-6": ["pane::ActivateItem", 5],
            "cmd-7": ["pane::ActivateItem", 6],
            "cmd-8": ["pane::ActivateItem", 7],
            "cmd-9": "pane::ActivateLastItem",
        },
    },
    {
        "context": "os == linux && Pane",
        "bindings": {
            "ctrl-1": ["pane::ActivateItem", 0],
            "ctrl-2": ["pane::ActivateItem", 1],
            "ctrl-3": ["pane::ActivateItem", 2],
            "ctrl-4": ["pane::ActivateItem", 3],
            "ctrl-5": ["pane::ActivateItem", 4],
            "ctrl-6": ["pane::ActivateItem", 5],
            "ctrl-7": ["pane::ActivateItem", 6],
            "ctrl-8": ["pane::ActivateItem", 7],
            "ctrl-9": "pane::ActivateLastItem",
        },
    },
    {
        "context": "os == macos && Workspace",
        "bindings": {
            "ctrl-cmd-p": ["projects::OpenRecent", { "create_new_window": false }],
        },
    },
    {
        "context": "os == linux && Workspace",
        "bindings": {
            "ctrl-alt-p": ["projects::OpenRecent", { "create_new_window": false }],
        },
    },
]
