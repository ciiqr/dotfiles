// documentation: https://zed.dev/docs/configuring-zed
{
    // editor
    "disable_ai": true,
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "cli_default_open_behavior": "new_window",
    "colorize_brackets": true,
    // "base_keymap": "SublimeText", // TODO: maybe (would prefer platform base without vscode stuff) "base_keymap": "None",
    "semantic_tokens": "combined",
    // "lsp_document_colors": "background",
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "theme": {
        "mode": "dark",
        "light": "Kaio",
        "dark": "Kaio",
    },
    "global_lsp_settings": {
        "semantic_token_rules": [
            {
                "token_type": "function",
                "token_modifiers": ["declaration"],
                "style": ["function.definition"],
            },
        ],
    },
    "auto_install_extensions": {
        "html": true,
        "toml": true,
        "dark-material-dracula": true,
        "scm": true,
        "git-firefly": true,
        "note": true,
        "color-highlight": true,
        "comment": true,
    },
    // "buffer_font_features": {
    //     // !==
    //     "calt": false,
    //     "liga": false,
    //     "dlig": false,
    // },
    "ui_font_family": "Inconsolata",
    "buffer_font_family": "Inconsolata",
    "macos": {
        "ui_font_size": 18,
        "buffer_font_size": 18,
    },
    "linux": {
        "ui_font_size": 16,
        "buffer_font_size": 16,
    },
    "ui_font_size": 18,
    "buffer_font_size": 18,
    "cursor_blink": false,
    "wrap_guides": [80, 100, 120],
    "tab_size": 4,
    "edit_predictions": {
        "provider": "none",
    },
    "extend_comment_on_newline": false,
    "title_bar": {
        "show_branch_name": false,
        "show_project_items": true,
    },
    "tab_bar": {
        "show_nav_history_buttons": false,
        "show_tab_bar_buttons": false,
    },
    "tabs": {
        // "file_icons": true,
        "close_position": "right",
    },
    "toolbar": {
        "quick_actions": false,
    },
    "status_bar": {
        "show_active_file": true,
    },
    "gutter": {
        // TODO: setting changed: "code_actions": false,
    },
    "search": {
        "include_ignored": true,
        "regex": true,
    },
    "file_scan_exclusions": [
        // default
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/.jj",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/.classpath",
        "**/.settings",

        // javascript
        "**/dist",
        "**/node_modules",
        "**/.next",
        "**/*.android.bundle",
        // syncthing
        "**/.stfolder",
        "**/.stversions",
        // zig
        "**/.zig-cache",
        "**/zig-out",
    ],
    "file_types": {
        "JSONC": ["**/.config/zed/themes/*.json"],
    },
    // "show_whitespaces": "all",
    // "file_scan_exclusions": null,
    "git": {
        // "disable_git": true,
        "inline_blame": {
            "enabled": false,
        },
    },
    "use_system_window_tabs": true,
    "close_panel_on_toggle": true,
    "project_panel": { "dock": "right" },
    "git_panel": { "dock": "right" },
    "outline_panel": { "dock": "right" },
    "collaboration_panel": { "dock": "right" },
    "agent": { "dock": "right" },

    // formatter
    "prettier": {
        // NOTE: for files without an associated prettier config
        "tabWidth": 4,
    },
    // language servers
    "lsp": {
        "eslint": {
            "settings": {
                "workingDirectory": {
                    "mode": "auto",
                },
                "problems": {
                    "shortenToSingleLine": true,
                },
                "rulesCustomizations": [
                    // set all eslint errors/warnings to show as warnings
                    {
                        "rule": "*",
                        "severity": "warn",
                    },
                    // disable import/no-unused-modules from showing (mostly just annoying while in the middle of coding)
                    {
                        "rule": "import/no-unused-modules",
                        "severity": "off",
                    },
                ],
            },
        },
        // TODO: do we need this?
        // "yaml-language-server": {
        //     "settings": {
        //         "yaml": {
        //             "schemas": {
        //                 "https://json.schemastore.org/github-workflow": [
        //                     "/.github/workflows/*.yml"
        //                 ]
        //             }
        //         }
        //     }
        // },
        "rust-analyzer": {
            "initialization_options": {
                "check": {
                    "command": "clippy",
                },
            },
        },
    },
    "code_actions_on_format": {
        "source.fixAll.eslint": true,
    },
    "languages": {
        "TypeScript": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
        "TSX": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
        "JavaScript": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
        "Markdown": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
        "JSON": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
        "Shell Script": {
            "formatter": {
                "external": {
                    "command": "node_modules/.bin/prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
        },
    },
}
